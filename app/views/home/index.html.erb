<!-- app/views/home/index.html.erb -->
<div class="bg-white rounded-lg shadow-sm overflow-hidden">
  <!-- ヒーローセクション -->
  <div class="relative bg-green-50">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-r from-green-100 to-green-50 opacity-80"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <div class="lg:grid lg:grid-cols-12 lg:gap-8">
        <div class="lg:col-span-6">
          <h1 class="text-4xl font-extrabold tracking-tight text-green-900 sm:text-5xl">
            愛犬と飼い主を繋ぐ<br>信頼のマッチングサービス
          </h1>
          <p class="mt-6 text-xl text-gray-600">
            大切な家族の一員である愛犬を、経験豊富なシッターにお任せください。Doggy Buddyはあなたと愛犬にぴったりのシッターを見つけるお手伝いをします。
          </p>
          <div class="mt-8 flex flex-col space-y-4 sm:flex-row sm:space-y-0 sm:space-x-4">
            <%= link_to "シッターを探す", "#", class: "inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
            <%= link_to "シッターに登録する", "#", class: "inline-flex items-center justify-center px-6 py-3 border border-gray-300 shadow-sm text-base font-medium rounded-md text-green-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
          </div>
        </div>
        <div class="mt-12 relative lg:mt-0 lg:col-span-6">
          <div class="relative mx-auto max-w-md px-4 sm:max-w-3xl lg:px-0">
            <%#= image_tag "hero-dog.jpg", class: "rounded-lg shadow-xl ring-1 ring-black ring-opacity-5", alt: "愛犬とシッター" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- サービスの特徴 -->
  <div class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
          Doggy Buddyの特徴
        </h2>
        <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-500">
          あなたと愛犬に最適なサービスをお届けします
        </p>
      </div>

      <div class="mt-12">
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
          <div class="pt-6">
            <div class="flow-root bg-gray-50 rounded-lg px-6 pb-8">
              <div class="-mt-6">
                <div>
                  <span class="inline-flex items-center justify-center p-3 bg-green-500 rounded-md shadow-lg">
                    <svg class="h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </span>
                </div>
                <h3 class="mt-8 text-lg font-medium text-gray-900 tracking-tight">安心の身元確認</h3>
                <p class="mt-5 text-base text-gray-500">
                  すべてのシッターは身元確認済み。犬の扱いに慣れた信頼できる方々ばかりです。サービス利用前の顔合わせも可能です。
                </p>
              </div>
            </div>
          </div>

          <div class="pt-6">
            <div class="flow-root bg-gray-50 rounded-lg px-6 pb-8">
              <div class="-mt-6">
                <div>
                  <span class="inline-flex items-center justify-center p-3 bg-green-500 rounded-md shadow-lg">
                    <svg class="h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </span>
                </div>
                <h3 class="mt-8 text-lg font-medium text-gray-900 tracking-tight">柔軟なスケジュール</h3>
                <p class="mt-5 text-base text-gray-500">
                  急な外出や長期の旅行など、あなたのニーズに合わせたシッティングが可能です。空き状況をリアルタイムで確認できます。
                </p>
              </div>
            </div>
          </div>

          <div class="pt-6">
            <div class="flow-root bg-gray-50 rounded-lg px-6 pb-8">
              <div class="-mt-6">
                <div>
                  <span class="inline-flex items-center justify-center p-3 bg-green-500 rounded-md shadow-lg">
                    <svg class="h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                  </span>
                </div>
                <h3 class="mt-8 text-lg font-medium text-gray-900 tracking-tight">リアルタイム報告</h3>
                <p class="mt-5 text-base text-gray-500">
                  シッティング中も写真や動画でワンちゃんの様子をお知らせします。不安なくお出かけをお楽しみいただけます。
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 利用の流れ -->
  <div class="py-16 bg-green-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
          ご利用の流れ
        </h2>
        <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-500">
          簡単3ステップでシッターを探せます
        </p>
      </div>

      <div class="mt-16">
        <div class="lg:grid lg:grid-cols-3 lg:gap-8">
          <div>
            <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-500 text-white">
              <span class="text-lg font-bold">1</span>
            </div>
            <div class="mt-5">
              <h3 class="text-lg leading-6 font-medium text-gray-900">条件を入力</h3>
              <p class="mt-2 text-base text-gray-500">
                日程や場所、ワンちゃんの特性などの条件を入力して、最適なシッターを検索します。お住まいの地域や日時から簡単に探せます。
              </p>
            </div>
          </div>

          <div class="mt-10 lg:mt-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-500 text-white">
              <span class="text-lg font-bold">2</span>
            </div>
            <div class="mt-5">
              <h3 class="text-lg leading-6 font-medium text-gray-900">シッターとチャット</h3>
              <p class="mt-2 text-base text-gray-500">
                気になるシッターとチャットで詳細を相談。事前にお互いを知ることで安心してお任せできます。愛犬の好みや習慣も伝えられます。
              </p>
            </div>
          </div>

          <div class="mt-10 lg:mt-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-500 text-white">
              <span class="text-lg font-bold">3</span>
            </div>
            <div class="mt-5">
              <h3 class="text-lg leading-6 font-medium text-gray-900">予約確定</h3>
              <p class="mt-2 text-base text-gray-500">
                条件が合えば予約を確定。安全な決済システムで支払いも簡単です。当日の流れもアプリ内で確認できるので安心です。
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="bg-green-700">
    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:py-16 lg:px-8 lg:flex lg:items-center lg:justify-between">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        <span class="block">愛犬のために最高のケアを</span>
        <span class="block text-green-200">今すぐ始めましょう</span>
      </h2>
      <div class="mt-8 flex lg:mt-0 lg:flex-shrink-0">
        <div class="inline-flex rounded-md shadow">
          <%= link_to "無料会員登録", "#", class: "inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-green-700 bg-white hover:bg-green-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white" %>
        </div>
        <div class="ml-3 inline-flex rounded-md shadow">
          <%= link_to "詳しく見る", "#", class: "inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-white bg-green-600 hover:bg-green-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
        </div>
      </div>
    </div>
  </div>
</div>
